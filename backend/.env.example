APP_ENV=local
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_IMAGE_DETAIL=high
OPENAI_VISION_TIMEOUT_SECONDS=3.8
OPENAI_MAX_IMAGE_LONG_EDGE=1280
OPENAI_JPEG_QUALITY=85
OPENAI_MIN_JPEG_QUALITY=82
OPENAI_MAX_PROCESSED_BYTES=2097152
OPENAI_MAX_IMAGE_PIXELS=20000000
